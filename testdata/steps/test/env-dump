#!/usr/bin/env bash
# test/env-dump — process-level fake step that records the contract env into an
# artifact, so a Go test can assert the runner injects METIS_EXP_DIR / METIS_SEED
# (the M3 contract additions) alongside the M2 vars. No Python / uv needed.
set -euo pipefail
d="${METIS_STEP_DIR:-$PWD}"
{
  echo "STEP_DIR=$METIS_STEP_DIR"
  echo "RUN_DIR=$METIS_RUN_DIR"
  echo "STEP_ID=$METIS_STEP_ID"
  echo "EXP_DIR=$METIS_EXP_DIR"
  echo "SEED=$METIS_SEED"
} > "$d/env.txt"
